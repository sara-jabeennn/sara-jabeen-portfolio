# Copy to .env.local and fill in real values. .env.local is gitignored and
# must never be committed. See CLAUDE.md > Contact form / GitHub integration.

# Resend API key - contact form send fails loudly in dev if this is missing,
# it never silently falls back to mailto. Get one at https://resend.com.
RESEND_API_KEY=

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=syedajabean@gmail.com

# Fine-grained GitHub PAT, public-repo read scope is enough. Used server-side
# only for the contribution graph / latest-repos widget - never sent to the
# client.
GITHUB_TOKEN=
